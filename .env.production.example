# =============================================================================
# AI Token 管家 — 生产环境变量模板
# 使用方法：cp .env.production.example .env && 编辑 .env 填入实际值
# =============================================================================

# ===== 飞书应用（必须配置） =====
# 在飞书开放平台创建企业自建应用后获取
FEISHU_APP_ID=cli_your_app_id
FEISHU_APP_SECRET=your_app_secret
# 回调地址，必须与飞书应用后台配置一致
FEISHU_REDIRECT_URI=https://ai.yourcompany.com/api/auth/feishu/callback

# ===== Next.js 前端需要的飞书配置（浏览器可见，不含敏感信息） =====
NEXT_PUBLIC_FEISHU_APP_ID=cli_your_app_id
NEXT_PUBLIC_FEISHU_REDIRECT_URI=https://ai.yourcompany.com/api/auth/feishu/callback

# ===== JWT 密钥（必须修改！至少 32 位随机字符串） =====
# 生成方法：openssl rand -hex 32
JWT_SECRET=your-random-secret-at-least-32-characters-long

# ===== 管理员邮箱（逗号分隔，首次登录时自动授予 admin 角色） =====
ADMIN_EMAILS=admin@yourcompany.com,it@yourcompany.com

# ===== 端口配置 =====
PROXY_PORT=3001
WEB_PORT=3000

# ===== 代理网关 =====
# 容器内部访问地址（web → proxy 通信用）
PROXY_BASE_URL=http://proxy:3001
# 管理后台地址（proxy CORS 白名单用）
WEB_URL=https://ai.yourcompany.com

# ===== 数据库路径 =====
# Docker 容器内使用共享卷路径，本地开发使用相对路径
DATABASE_URL=/data/data.db

# ===== Node 环境 =====
NODE_ENV=production
